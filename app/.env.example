# ------------------------------------------------------------
# Neon Postgres
# Get from: neon.tech -> your project -> Connection Details -> pooled connection
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# ------------------------------------------------------------
# Auth.js
# AUTH_SECRET: generate with `npx auth secret`
# ------------------------------------------------------------
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"          # set to your Netlify URL in production

# ------------------------------------------------------------
# Google OAuth
# Get from: console.cloud.google.com -> APIs & Services -> Credentials
# Redirect URI to register: <AUTH_URL>/api/auth/callback/google
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ------------------------------------------------------------
# R2: users connect their OWN bucket via the in-app "Connect Storage"
# flow (/api/storage/connect) — nothing platform-level to set here.
# ------------------------------------------------------------

# ------------------------------------------------------------
# Key Vault (Cloudflare Worker) — free alternative to AWS/GCP KMS.
# See /yoloforge-keyvault for the Worker's own source + deploy steps.
#
# KEYVAULT_URL: the Worker's deployed URL, e.g.
#   https://yoloforge-keyvault.<your-subdomain>.workers.dev
# KEYVAULT_SHARED_TOKEN: must EXACTLY match the SHARED_AUTH_TOKEN secret
#   set on the Worker itself (via `wrangler secret put SHARED_AUTH_TOKEN`).
#   Generate once with: openssl rand -hex 32
# ------------------------------------------------------------
KEYVAULT_URL=""
KEYVAULT_SHARED_TOKEN=""
