# ============================================================
# Shared across both app/ and keyvault/
# ============================================================

# dependencies
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# env files — NEVER commit real values, only .env.example / .dev.vars.example
**/.env*
!**/.env.example
**/.dev.vars*
!**/.dev.vars.example

# never commit anything that looks like a real credential dump
*.pem
*.key
*credentials*.json
*secret*.json

# misc
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# ============================================================
# app/ (Next.js) specific
# ============================================================
app/.next/
app/out/
app/build
app/.vercel
app/next-env.d.ts
app/coverage

# ============================================================
# keyvault/ (Cloudflare Worker) specific
# ============================================================
keyvault/.wrangler/
keyvault/.dev.vars
